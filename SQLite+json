6. Integrando com WebView
Você pode criar uma Interface JavaScript:




Java
public class WebAppInterface {

    Context context;

    public WebAppInterface(Context context) {
        this.context = context;
    }

    @JavascriptInterface
    public String buscarProduto(int id) {

        BancoHelper helper =
                new BancoHelper(context);

        SQLiteDatabase db =
                helper.getReadableDatabase();

        Cursor cursor = db.rawQuery(
            "SELECT * FROM produtos WHERE id=?",
            new String[]{String.valueOf(id)}
        );

        JSONObject obj = new JSONObject();

        try {

            if(cursor.moveToFirst()) {

                obj.put("id",
                    cursor.getInt(
                    cursor.getColumnIndexOrThrow("id")));

                obj.put("nome",
                    cursor.getString(
                    cursor.getColumnIndexOrThrow("nome")));

                obj.put("preco",
                    cursor.getDouble(
                    cursor.getColumnIndexOrThrow("preco")));
            }

        } catch(Exception e) {
            e.printStackTrace();
        }

        cursor.close();
        db.close();

        return obj.toString();
    }
}

