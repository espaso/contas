3. Importar JSON para SQLite



Java
JSONArray array = new JSONArray(jsonRecebido);

BancoHelper helper = new BancoHelper(this);
SQLiteDatabase db = helper.getWritableDatabase();

db.beginTransaction();

try {

    db.delete("produtos", null, null);

    for (int i = 0; i < array.length(); i++) {

        JSONObject obj = array.getJSONObject(i);

        ContentValues cv = new ContentValues();

        cv.put("id", obj.getInt("id"));
        cv.put("nome", obj.getString("nome"));
        cv.put("preco", obj.getDouble("preco"));

        db.insert("produtos", null, cv);
    }

    db.setTransactionSuccessful();

} finally {

    db.endTransaction();
    db.close();
}

